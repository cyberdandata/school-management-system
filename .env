# GitHub Repository
GITHUB_REPO_URL=https://github.com/your-org/school-management-system.git
GIT_BRANCH=main

# Sync Settings
SYNC_INTERVAL=300000
SYNC_AUTO_PUSH=true
SYNC_AUTO_PULL=true
SYNC_CONFLICT_RESOLUTION=merge

# Server URL for remote sync
SERVER_URL=http://localhost:3000
SYNC_TOKEN=your-secret-token